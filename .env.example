# 利尻島昆布干場予報システム - 環境変数設定例

# Flask設定
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_here_change_this_in_production

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
WEATHER_API_KEY=your_weather_api_key_here

# データベース (オプション)
DATABASE_URL=postgresql://user:password@host:port/database
REDIS_URL=redis://user:password@host:port

# セキュリティ設定
CORS_ORIGINS=https://your-domain.com
RATE_LIMIT_PER_MINUTE=60

# ログレベル
LOG_LEVEL=INFO

# モニタリング
SENTRY_DSN=your_sentry_dsn_here

# 外部サービス
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# システム設定
CACHE_EXPIRE_HOURS=6
MAX_CACHE_SIZE_MB=100
BACKUP_RETENTION_DAYS=30

# 地理設定 (利尻島)
DEFAULT_LAT=45.178269
DEFAULT_LON=141.228528
SERVICE_AREA_RADIUS_KM=50

# PWA設定
PWA_MANIFEST_START_URL=/
PWA_MANIFEST_SCOPE=/
PWA_THEME_COLOR=#667eea
PWA_BACKGROUND_COLOR=#ffffff

# パフォーマンス設定
MAX_WORKERS=2
WORKER_TIMEOUT=120
STATIC_FILE_CACHE_SECONDS=86400

# 通知設定
NOTIFICATION_RATE_LIMIT=10
SMS_API_KEY=your_sms_api_key

# LINE Messaging API 設定
# LINE Developers Console (https://developers.line.biz/) で取得
LINE_ENABLED=false
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# /api/line/notify 呼び出し時の認証シークレット（Render Cron Job 用）
LINE_ADMIN_NOTIFY_SECRET=your_admin_notify_secret_here
# LINE 友だち追加URL（例: https://lin.ee/xxxxxxx）
# 設定すると kelp_drying_map.html に友だち追加バナーが自動表示される。
# 未設定の場合はバナー非表示。/api/line/status から HTML が取得する。
LINE_ADD_FRIEND_URL=